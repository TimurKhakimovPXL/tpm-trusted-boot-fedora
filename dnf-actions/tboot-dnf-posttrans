    _emit_dir_content "$c" /usr/lib/udev/rules.d
}

_cat06_modprobe_load() {
    local c="06-modprobe-load"
    _emit_dir_content "$c" /etc/modprobe.d
    _emit_dir_content "$c" /usr/lib/modprobe.d
