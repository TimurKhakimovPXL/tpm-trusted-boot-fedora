_cat09_tpm2_tss() {
    local c="09-tpm2-tss"
    _emit_dir_meta_filtered "$c" /usr/sbin  -maxdepth 1 -name 'tpm2_*'
    _emit_dir_meta_filtered "$c" /usr/lib64 -maxdepth 1 -name 'libtss2-*'
